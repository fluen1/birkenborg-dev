---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Marginalia from '../../components/Marginalia.astro';
import MetaTags from '../../components/MetaTags.astro';
import StructuredData from '../../components/StructuredData.astro';
import { formatDate } from '../../lib/format-date';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.status === 'published');
  return posts.map(p => ({
    params: { slug: p.id.replace(/\.md$/, '') },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const rawBody = post.body ?? '';
const wordCount = rawBody.replace(/[*#`>\[\]_]/g, '').trim().split(/\s+/).filter(Boolean).length;

// Relaterede skrifter via tag-overlap
const allPosts = await getCollection('posts', ({ data }) => data.status === 'published' && !data.privacy_flag);
const currentSlug = post.id.replace(/\.md$/, '');
const currentTags = post.data.tags ?? [];

type RelatedPost = { slug: string; title: string; publishAt: Date; score: number };
const related: RelatedPost[] = allPosts
  .filter(p => p.id.replace(/\.md$/, '') !== currentSlug)
  .map(p => {
    const otherTags = p.data.tags ?? [];
    const overlap = currentTags.filter(t => otherTags.includes(t)).length;
    return {
      slug: p.data.slug ?? p.id.replace(/\.md$/, ''),
      title: p.data.title,
      publishAt: p.data.publish_at,
      score: overlap,
    };
  })
  .filter(r => r.score > 0)
  .sort((a, b) => b.score - a.score || +b.publishAt - +a.publishAt)
  .slice(0, 3);
---
<Base title={`${post.data.title} · birkenborg.dev`}>
  <Fragment slot="head">
    <MetaTags
      title={`${post.data.title} · birkenborg.dev`}
      description={post.data.excerpt ?? post.data.title}
      url={`https://birkenborg.dev/skrifter/${post.data.slug ?? post.id.replace(/\.md$/, '')}`}
      type="article"
      publishedTime={post.data.publish_at.toISOString()}
      imageUrl={`https://birkenborg.dev/og/posts/${post.id.replace(/\.md$/, '')}.png`}
    />
    <StructuredData
      type="Article"
      data={{
        headline: post.data.title,
        datePublished: post.data.publish_at.toISOString(),
        dateModified: post.data.publish_at.toISOString(),
        author: {
          '@type': 'Person',
          name: 'Philip Birkenborg',
          url: 'https://birkenborg.dev',
        },
        publisher: {
          '@type': 'Person',
          name: 'Philip Birkenborg',
        },
        description: post.data.excerpt ?? post.data.title,
        url: `https://birkenborg.dev/skrifter/${post.data.slug ?? post.id.replace(/\.md$/, '')}`,
        image: `https://birkenborg.dev/og/posts/${post.id.replace(/\.md$/, '')}.png`,
        keywords: (post.data.tags ?? []).join(', '),
        wordCount,
        inLanguage: 'da-DK',
        articleSection: 'Skrifter',
      }}
    />
  </Fragment>
  <Header />
  <main class="post-page">
    <div class="post-layout container">
      <article class="post-content">
        <header class="post-head">
          <p class="meta">{formatDate(post.data.publish_at)}</p>
          <h1 transition:name={`skrift-${currentSlug}`}>{post.data.title}</h1>
          {post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
        </header>
        <div class="post-body">
          <Content />
        </div>
        {post.data.linkedin_url && (
          <footer class="post-foot">
            <a href={post.data.linkedin_url} target="_blank" rel="noopener">Læs også på LinkedIn →</a>
          </footer>
        )}
        {related.length > 0 && (
          <aside class="related">
            <h2>Relaterede skrifter</h2>
            <ul>
              {related.map(r => (
                <li>
                  <a href={`/skrifter/${r.slug}`}>
                    {r.title}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )}
        <aside class="ask-cta" data-reveal>
          <a href={`/chat?about=${currentSlug}`}>
            Spørg Philip-bot om <em>dette skrift</em> →
          </a>
        </aside>
      </article>
      <aside class="post-margin">
        <Marginalia notes={post.data.marginalia ?? []} />
      </aside>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .post-page { padding: 64px 0 96px; }

  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 200px;
    gap: 48px;
    align-items: start;
  }

  .post-content { min-width: 0; }

  .post-margin {
    position: sticky;
    top: 96px;
    padding-top: 0;
  }

  .post-head { max-width: 720px; margin: 0 auto 48px; }
  .meta {
    font-size: 12px; letter-spacing: .15em; text-transform: uppercase;
    color: var(--gray-700); margin: 0 0 16px;
  }
  .post-head h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 350;
    line-height: 1.1;
    letter-spacing: -.02em;
    margin: 0 0 20px;
    font-variation-settings: 'opsz' 144;
  }
  .excerpt {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px; line-height: 1.55;
    color: var(--gray-700);
    margin: 0;
  }
  .post-body {
    max-width: 720px; margin: 0 auto;
    font-family: var(--font-serif);
    font-size: 18px; line-height: 1.7;
  }
  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 400;
    margin: 48px 0 16px;
    font-variation-settings: 'opsz' 144;
  }
  .post-body :global(p) { margin: 0 0 24px; }
  .post-body :global(a) { color: var(--clay-deep); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 24px; padding-left: 1.4em; }
  .post-body :global(li) { margin-bottom: 8px; }
  .post-body :global(code) {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: .92em;
    background: var(--gray-100);
    padding: 1px 6px; border-radius: 4px;
  }
  .post-foot {
    max-width: 720px; margin: 64px auto 0;
    padding-top: 24px; border-top: 1px solid var(--gray-100);
    font-size: 14px;
  }
  .post-foot a { color: var(--clay-deep); }

  .related {
    max-width: 720px;
    margin: 64px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--gray-100);
  }
  .related h2 {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray-700);
    margin: 0 0 16px;
  }
  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related li {
    margin-bottom: 10px;
    font-size: 16px;
  }
  .related a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .related a:hover {
    border-bottom-color: var(--clay-xdeep);
  }

  .ask-cta {
    max-width: 720px;
    margin: 48px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--gray-100);
  }
  .ask-cta a {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--gray-700);
    transition: color 0.15s;
  }
  .ask-cta a em {
    color: var(--clay-deep);
    font-style: italic;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ask-cta a:hover { color: var(--ink); }
  .ask-cta a:hover em { text-decoration-color: var(--clay-deep); }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; gap: 16px; }
    .post-margin { position: static; padding-top: 24px; }
  }
</style>
