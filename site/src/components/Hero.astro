---
interface Props {
  eyebrow?: string;
  ctaPrimary?: { href: string; label: string };
  ctaSecondary?: { href: string; label: string };
}

const {
  eyebrow = 'Aktiv · 10 agents i produktion',
  ctaPrimary = { href: '/skrifter', label: 'Læs seneste skrift' },
  ctaSecondary = { href: '/projekter', label: 'Se projekter' },
} = Astro.props;
---
<section class="hero">
  <div class="container">
    <span class="eyebrow"><span class="dot"></span>{eyebrow}</span>
    <h1 class="headline">In-house jurist der bygger <em>de værktøjer</em> mine kolleger taler om at bygge.</h1>
    <p class="deck">Cand.merc.jur. Legal Counsel hos Tandlægen.dk. Bruger fritiden på at automatisere den juridiske hverdag — og deler hvad der virker, og præcist hvor det fejler.</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={ctaPrimary.href}>{ctaPrimary.label} <span class="arrow">→</span></a>
      <a class="btn btn-secondary" href={ctaSecondary.href}>{ctaSecondary.label}</a>
    </div>
  </div>
</section>

<style>
  .hero { padding: 96px 0 72px; position: relative; }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 500;
    color: var(--clay-deep);
    background: rgba(217,119,87,.1);
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(217,119,87,.2);
    margin-bottom: 28px;
    animation: fadeUp .8s ease both;
  }
  .eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--clay);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(217,119,87,.5); }
    50%     { box-shadow: 0 0 0 6px rgba(217,119,87,0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .headline {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: clamp(48px, 6.5vw, 88px);
    line-height: 1.02;
    letter-spacing: -.025em;
    margin: 0 0 24px;
    max-width: 880px;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
    animation: fadeUp .9s .05s ease both;
  }
  .headline em { font-style: italic; color: var(--clay); font-weight: 400; }
  .deck {
    font-size: 19px; line-height: 1.55;
    color: var(--gray-700);
    max-width: 620px;
    margin: 0 0 36px;
    animation: fadeUp 1s .15s ease both;
  }
  .cta-row {
    display: flex; gap: 12px; flex-wrap: wrap;
    animation: fadeUp 1s .25s ease both;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    border-radius: 999px;
    font-size: 14px; font-weight: 500;
    transition: transform .15s ease, box-shadow .2s, background .2s;
  }
  .btn-primary { background: var(--ink); color: var(--cream); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(20,20,19,.18); }
  .btn-secondary { background: transparent; color: var(--ink); border: 1px solid var(--gray-200); }
  .btn-secondary:hover { background: var(--gray-100); }
  .btn .arrow { transition: transform .2s; }
  .btn:hover .arrow { transform: translateX(3px); }
</style>
