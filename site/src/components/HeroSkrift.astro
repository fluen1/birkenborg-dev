---
interface Props {
  slug: string;
  title: string;
  publish_at: Date;
  excerpt?: string;
}

const { slug, title, publish_at, excerpt } = Astro.props;
const dateLabel = publish_at.toLocaleDateString('da-DK', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<section class="hero-skrift" data-reveal>
  <div class="label">Senest skrift · {dateLabel}</div>
  <h1 class="title" transition:name={`skrift-${slug}`}>
    <a href={`/skrifter/${slug}/`}>{title}</a>
  </h1>
  {excerpt && <p class="deck">{excerpt}</p>}
  <a class="read-more" href={`/skrifter/${slug}/`}>Læs videre <span class="arrow">→</span></a>
</section>

<style>
  .hero-skrift {
    border-left: 3px solid var(--clay);
    padding: 24px 0 24px 28px;
    margin: 56px 0 32px;
  }
  .label {
    font-size: 11px;
    font-weight: 700;
    color: var(--clay-xdeep);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
    font-family: var(--font-sans, system-ui);
  }
  .title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  /* Kinetisk variabel-font: titlen "sætter sig i fokus" når heroen reveales —
     optisk størrelse + vægt eases fra let/spredt til settled — og typen
     reagerer levende på hover. to-keyframet = base-værdien, så der ikke er
     noget visuelt snap når animationens fill slipper. */
  .title a {
    color: inherit;
    text-decoration: none;
    font-variation-settings: 'opsz' 144, 'wght' 400;
    transition: font-variation-settings 320ms ease, color 0.2s;
  }
  .title a:hover {
    color: var(--clay-deep);
    font-variation-settings: 'opsz' 144, 'wght' 560;
  }
  .hero-skrift.revealed .title a {
    animation: hero-typesettle 1100ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }
  @keyframes hero-typesettle {
    from { font-variation-settings: 'opsz' 22, 'wght' 250; letter-spacing: 0.07em; }
    to   { font-variation-settings: 'opsz' 144, 'wght' 400; letter-spacing: -0.02em; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-skrift.revealed .title a { animation: none; }
    .title a { transition: color 0.2s; }
  }
  .deck {
    font-size: 18px;
    line-height: 1.55;
    color: var(--gray-700);
    max-width: 620px;
    margin: 0 0 18px;
  }
  .read-more {
    font-size: 14px;
    color: var(--clay-xdeep);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .read-more .arrow { transition: transform 0.2s; }
  .read-more:hover .arrow { transform: translateX(3px); }

  @media (max-width: 720px) {
    .hero-skrift { padding-left: 18px; }
  }
</style>
