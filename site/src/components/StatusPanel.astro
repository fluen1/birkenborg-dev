---
interface Props {
  text: string;
  meta: string;
  label?: string;
}
const { text, meta, label = 'Lige nu' } = Astro.props;
---
<div class="status-panel">
  <span class="label"><span class="ldot"></span>{label}</span>
  <p class="text"><Fragment set:html={text} /></p>
  <span class="meta">{meta}</span>
</div>

<style>
  .status-panel {
    margin-top: 80px;
    padding: 24px 28px;
    background: var(--cream-warm);
    border: 1px solid var(--gray-100);
    border-radius: var(--r-lg);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 28px;
    box-shadow: var(--shadow-sm);
    animation: fadeUp 1s .35s ease both;
  }
  .label {
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--gray-700); font-weight: 600;
  }
  .ldot {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: var(--sage); margin-right: 8px;
    box-shadow: 0 0 0 3px rgba(120,140,93,.18);
  }
  .text { font-family: var(--font-serif); font-size: 17px; line-height: 1.5; margin: 0; }
  .text :global(em) { color: var(--clay-deep); font-style: italic; }
  .meta { font-size: 13px; color: var(--gray-700); }
  @media (max-width: 720px) {
    .status-panel { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
