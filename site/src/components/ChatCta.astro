---
// Discrete CTA der peger på /chat-siden.
// Placeret efter "Seneste skrifter" på forsiden — kontekstuelt nær det den handler om.
---

<aside class="chat-cta" data-reveal>
  <a href="/chat">
    Eller <em>snak med en bot</em> der kender alle Philips skrifter →
  </a>
</aside>

<style>
  .chat-cta {
    max-width: 720px;
    margin: 24px auto 0;
    text-align: left;
  }
  .chat-cta a {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--gray-700);
    line-height: 1.5;
    transition: color .15s;
  }
  .chat-cta a em {
    color: var(--clay-deep);
    font-style: italic;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .chat-cta a:hover { color: var(--ink); }
  .chat-cta a:hover em { text-decoration-color: var(--clay-deep); }
</style>
