---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="signature">
      Philip Birkenborg<br />
      <em>Cand.merc.jur.</em>
    </div>
    <div>
      <h5>Sider</h5>
      <ul>
        <li><a href="/skrifter">Skrifter</a></li>
        <li><a href="/projekter">Projekter</a></li>
        <li><a href="/cv">CV</a></li>
        <li><a href="/chat">Chat</a></li>
      </ul>
    </div>
    <div>
      <h5>Andre steder</h5>
      <ul>
        <li><a href="https://linkedin.com/in/philip-birkenborg-509794172/" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="https://retsklar.dk" target="_blank" rel="noopener">retsklar.dk</a></li>
        <li><a href="mailto:birkenborg.p@hotmail.com">E-mail</a></li>
      </ul>
    </div>
    <div class="colophon">
      <span>© {year} · Bygget med Astro, hostet på Cloudflare</span>
      <span>København</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 96px;
    border-top: 1px solid var(--gray-100);
    background: var(--cream-warm);
    padding: 44px 0 32px;
  }
  .site-footer .container {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 32px;
  }
  .signature {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 350;
    line-height: 1.2;
    font-variation-settings: 'opsz' 144;
  }
  .signature em { color: var(--clay); font-style: italic; }
  h5 {
    font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
    color: var(--gray-700); margin: 0 0 14px; font-weight: 600;
  }
  ul { list-style: none; padding: 0; margin: 0; }
  li { margin-bottom: 8px; font-size: 14px; }
  li a:hover { color: var(--clay-deep); }
  .colophon {
    grid-column: 1/-1;
    margin-top: 36px; padding-top: 20px;
    border-top: 1px solid var(--gray-100);
    display: flex; justify-content: space-between;
    font-size: 12px; color: var(--gray-400);
  }
  @media (max-width: 720px) {
    .site-footer .container { grid-template-columns: 1fr; gap: 24px; }
    .colophon { flex-direction: column; gap: 6px; }
  }
</style>
