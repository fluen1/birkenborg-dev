---
// Live-signaler fra Worker /api/activity:
// - Aktivitets-graf (sidste 30 dage commits)
// - "Last commit"-info
// - Drafts-pending hvis bot har inbox-beskeder
//
// Initial render er skeleton; data fetches client-side ved load.
---

<aside class="live" aria-label="Live status">
  <div class="head">
    <span class="ldot" aria-hidden="true"></span>
    <span class="label">Live</span>
    <span class="meta" data-meta>henter status…</span>
  </div>

  <p class="line" data-line>
    <span class="skeleton" style="width: 280px"></span>
  </p>

  <svg class="graph" viewBox="0 0 600 64" preserveAspectRatio="none" aria-hidden="true">
    <g data-bars></g>
  </svg>

  <div class="footer">
    <span class="hint" data-hint>Aktivitet sidste 30 dage</span>
    <a class="github" href="https://github.com/fluen1" target="_blank" rel="noopener">github.com/fluen1 →</a>
  </div>
</aside>

<script>
  interface DayCount {
    date: string;
    count: number;
  }
  interface ActivityResponse {
    activity: DayCount[];
    lastCommit: { repo: string; message: string; ts: number; url: string } | null;
    draftsPending: number | null;
    generatedAt: number;
  }

  const root = document.querySelector(".live") as HTMLElement | null;
  if (root) {
    const lineEl = root.querySelector("[data-line]") as HTMLElement;
    const metaEl = root.querySelector("[data-meta]") as HTMLElement;
    const hintEl = root.querySelector("[data-hint]") as HTMLElement;
    const barsEl = root.querySelector("[data-bars]") as SVGGElement;

    // Beskeder vi ikke vil vise som "hvad jeg byggede" — for vague til at signalere noget
    const isInformativeMessage = (msg: string): boolean => {
      const lower = msg.toLowerCase();
      if (lower.startsWith("merge ")) return false;
      if (lower.startsWith("merge:")) return false;
      if (lower.startsWith("merge branch")) return false;
      if (lower.startsWith("wip")) return false;
      if (lower.startsWith("fixup!")) return false;
      if (lower === "fix" || lower === "update" || lower === "wip") return false;
      return msg.length >= 8;
    };

    // Trim conventional-commit-prefix (worker:, feat(x):, fix:, etc.) for læsbarhed
    const cleanMessage = (msg: string): string => {
      const m = msg.match(/^[a-z]+(\([^)]+\))?:\s*(.+)$/);
      return (m?.[2] ?? msg).trim();
    };

    const renderLine = (data: ActivityResponse): void => {
      lineEl.replaceChildren();
      const segments: Array<DocumentFragment | string> = [];

      if (data.lastCommit) {
        const diff = Math.floor(Date.now() / 1000) - data.lastCommit.ts;
        const showMessage = isInformativeMessage(data.lastCommit.message);
        const frag = document.createDocumentFragment();

        let prefix: string;
        if (diff < 6 * 3600) prefix = "Lige bygget på ";
        else if (diff < 24 * 3600) prefix = "I dag på ";
        else if (diff < 48 * 3600) prefix = "I går på ";
        else if (diff < 7 * 86400) {
          const days = Math.floor(diff / 86400);
          prefix = `For ${days} dage siden på `;
        } else prefix = "Sidste commit på ";

        frag.appendChild(document.createTextNode(prefix));
        const em = document.createElement("em");
        em.textContent = data.lastCommit.repo;
        frag.appendChild(em);

        if (showMessage && diff < 7 * 86400) {
          frag.appendChild(document.createTextNode(": "));
          frag.appendChild(document.createTextNode(cleanMessage(data.lastCommit.message)));
        } else if (!showMessage && diff >= 7 * 86400) {
          const days = Math.floor(diff / 86400);
          frag.appendChild(document.createTextNode(` — ${days} dage siden`));
        } else if (!showMessage) {
          // Within last week, but uninteresting message — just show recency
          if (diff < 3600) frag.appendChild(document.createTextNode(" — lige nu"));
          else if (diff < 86400) frag.appendChild(document.createTextNode(` — ${Math.floor(diff / 3600)} timer siden`));
        }

        segments.push(frag);
      }

      if (data.draftsPending && data.draftsPending > 0) {
        const word = data.draftsPending === 1 ? "tanke" : "tanker";
        segments.push(`${data.draftsPending} ${word} i kø til søndagens drafts`);
      }

      if (!segments.length) {
        lineEl.textContent = "Stille for tiden — næste publish onsdag";
        return;
      }

      segments.forEach((seg, idx) => {
        if (idx > 0) lineEl.appendChild(document.createTextNode(" · "));
        if (typeof seg === "string") {
          lineEl.appendChild(document.createTextNode(seg));
        } else {
          lineEl.appendChild(seg);
        }
      });
    };

    const renderBars = (activity: DayCount[]): void => {
      barsEl.replaceChildren();
      const ns = "http://www.w3.org/2000/svg";
      const max = Math.max(1, ...activity.map((d) => d.count));
      const w = 600 / activity.length;
      const gap = 2;
      activity.forEach((d, i) => {
        const h = Math.max(2, (d.count / max) * 56);
        const y = 64 - h;
        const x = i * w;
        const opacity = d.count === 0 ? 0.18 : 0.5 + (d.count / max) * 0.5;
        const rect = document.createElementNS(ns, "rect");
        rect.setAttribute("x", x.toFixed(2));
        rect.setAttribute("y", y.toFixed(2));
        rect.setAttribute("width", (w - gap).toFixed(2));
        rect.setAttribute("height", h.toFixed(2));
        rect.setAttribute("rx", "1.5");
        rect.setAttribute("fill", "currentColor");
        rect.setAttribute("opacity", opacity.toFixed(2));
        const title = document.createElementNS(ns, "title");
        title.textContent = `${d.date}: ${d.count} commit${d.count === 1 ? "" : "s"}`;
        rect.appendChild(title);
        barsEl.appendChild(rect);
      });
    };

    fetch("/api/activity")
      .then((r) => r.json() as Promise<ActivityResponse>)
      .then((data) => {
        renderLine(data);
        const total = data.activity.reduce((sum, d) => sum + d.count, 0);
        metaEl.textContent = `${total} commits · sidste 30 dage`;
        hintEl.textContent = "Aktivitet sidste 30 dage";
        renderBars(data.activity);
      })
      .catch(() => {
        lineEl.textContent = "Kunne ikke hente live status — prøv igen om lidt.";
        metaEl.textContent = "";
      });
  }
</script>

<style>
  .live {
    margin-top: 80px;
    padding: 26px 30px 22px;
    background: var(--cream-warm);
    border: 1px solid var(--gray-100);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    color: var(--clay-deep);
    animation: fadeUp 1s 0.35s ease both;
  }
  .head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .ldot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--clay);
    box-shadow: 0 0 0 0 rgba(217, 119, 87, 0.55);
    animation: pulse 2.4s infinite;
  }
  .label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clay-deep);
    font-weight: 600;
  }
  .meta {
    margin-left: auto;
    font-size: 12px;
    color: var(--gray-700);
    font-feature-settings: "tnum";
  }
  .line {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.5;
    margin: 0 0 18px;
    color: var(--ink);
    min-height: 26px;
  }
  .line :global(em) {
    color: var(--clay-deep);
    font-style: italic;
  }
  .graph {
    width: 100%;
    height: 56px;
    color: var(--clay);
    display: block;
    margin-bottom: 10px;
  }
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--gray-700);
  }
  .github {
    color: var(--gray-700);
    text-decoration: none;
    transition: color 0.15s;
  }
  .github:hover {
    color: var(--clay-deep);
  }
  .skeleton {
    display: inline-block;
    height: 17px;
    background: linear-gradient(
      90deg,
      var(--gray-100) 0%,
      var(--gray-200) 50%,
      var(--gray-100) 100%
    );
    background-size: 200% 100%;
    border-radius: 3px;
    animation: shimmer 1.4s infinite;
  }
  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(217, 119, 87, 0.55);
    }
    50% {
      box-shadow: 0 0 0 7px rgba(217, 119, 87, 0);
    }
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (max-width: 720px) {
    .live {
      padding: 22px 20px 18px;
    }
    .meta {
      display: none;
    }
  }
</style>
