---
import { formatDateShort } from '../lib/format-date';

interface Props {
  href: string;
  title: string;
  date: Date | string;
  readTime?: string;
  headingLevel?: 'h2' | 'h3';
}
const { href, title, date, readTime = '5 min', headingLevel = 'h3' } = Astro.props;
const HeadingTag = headingLevel;
---
<a class="writing" href={href}>
  <span class="date">{formatDateShort(date)}</span>
  <HeadingTag>{title}</HeadingTag>
  <span class="read">{readTime}</span>
</a>

<style>
  .writing {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: baseline;
    gap: 32px;
    padding: 26px 0;
    border-bottom: 1px solid var(--gray-100);
    transition: padding .25s ease;
  }
  .writing:hover { padding-left: 12px; }
  .writing:hover h2, .writing:hover h3 { color: var(--clay-deep); }
  .date {
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    color: var(--gray-400);
  }
  h2, h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 22px;
    margin: 0;
    line-height: 1.3;
    transition: color .2s;
  }
  .read { font-size: 12px; color: var(--gray-400); font-variant-numeric: tabular-nums; }
  @media (max-width: 720px) {
    .writing { grid-template-columns: 64px 1fr; gap: 16px; }
    .read { display: none; }
    h2, h3 { font-size: 18px; }
  }
</style>
