---
interface Props {
  href: string;
  title: string;
  pillLabel: string;
  status: 'shipped' | 'alpha' | 'internal' | 'archived';
  summary: string;
  featured?: boolean;
}
const { href, title, pillLabel, status, summary, featured = false } = Astro.props;
const pillClass = `pill ${status}`;
---
<a class={`project ${featured ? 'featured' : ''}`} href={href}>
  <span class={pillClass}>{pillLabel}</span>
  <h3>{title}</h3>
  <p>{summary}</p>
  <span class="arrow-small">Læs mere →</span>
</a>

<style>
  .project {
    background: var(--cream-warm);
    border: 1px solid var(--gray-100);
    border-radius: var(--r-lg);
    padding: 28px;
    display: flex; flex-direction: column; gap: 14px;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    position: relative; overflow: hidden;
  }
  .project:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hov);
    border-color: var(--gray-200);
  }
  .pill {
    align-self: flex-start;
    font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 999px; font-weight: 600;
  }
  .pill.shipped  { background: rgba(120,140,93,.16); color: var(--sage); }
  .pill.alpha    { background: rgba(217,119,87,.14); color: var(--clay-deep); }
  .pill.internal { background: rgba(106,155,204,.14); color: #3a6a99; }
  .pill.archived { background: var(--gray-100); color: var(--gray-700); }
  h3 {
    font-family: var(--font-display);
    font-size: 26px; font-weight: 400; margin: 0;
    line-height: 1.15; letter-spacing: -.01em;
  }
  p {
    font-size: 14px; color: var(--gray-700); line-height: 1.55;
    margin: 0; flex-grow: 1;
  }
  .arrow-small {
    align-self: flex-start;
    font-size: 13px; color: var(--clay-deep); font-weight: 500;
    display: inline-flex; align-items: center; gap: 6px;
    transition: gap .2s;
  }
  .project:hover .arrow-small { gap: 12px; }

  .project.featured { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .project.featured h3 { color: var(--cream); }
  .project.featured p { color: rgba(250,249,245,.7); }
  .project.featured .arrow-small { color: var(--clay-soft); }
  .project.featured .pill.alpha { background: rgba(217,119,87,.22); color: var(--clay-soft); }
  .project.featured::after {
    content: ""; position: absolute; right: -40px; bottom: -40px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(217,119,87,.25) 0%, transparent 70%);
    pointer-events: none;
  }
</style>
